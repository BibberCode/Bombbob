# Unity Textdateien
*.cs       text eol=lf
*.shader   text eol=lf
*.json     text eol=lf
*.asmdef   text eol=lf
*.txt      text eol=lf
*.md       text eol=lf
*.mat      text eol=lf
*.prefs    text eol=lf
*.yaml     text eol=lf
# Unity spezifisch
*.asset    text eol=lf
*.meta     text eol=lf
*.unity    text eol=lf
*.controller text eol=lf
*.anim     text eol=lf
# Binärdateien nicht umwandeln
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg      binary
*.fbx filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.mp3      binary
*.ogg      binary
*.psd filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
